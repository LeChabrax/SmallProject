# Impulse Nutrition — environment variables template.
# Copy to .env and fill in. .env is git-ignored.
# All MCP servers and Python scripts at /common/, /scripts/ and
# /instagram_dm_mcp/ pick up values from here via python-dotenv.

# -- Google (shared between common/google_sheets.py and scripts) ------------
GOOGLE_SERVICE_ACCOUNT_PATH=/Users/you/.config/google-service-account.json

# -- Instagram (instagram_dm_mcp + scripts) ---------------------------------
INSTAGRAM_USERNAME=impulse_nutrition_fr
INSTAGRAM_PASSWORD=replace_me
# Veille account for competitor monitoring (optional)
INSTAGRAM_VEILLE_USERNAME=antman.lass
INSTAGRAM_VEILLE_PASSWORD=replace_me

# -- Gorgias (gorgias_mcp) --------------------------------------------------
# Subdomain only, without `.gorgias.com`.
GORGIAS_DOMAIN=impulse-nutrition-vitavea
GORGIAS_EMAIL=achabrat@havea.com
GORGIAS_API_KEY=replace_me

# -- Shopify (shopify_mcp + shaker-450ml-gratuit cloud function) ------------
SHOPIFY_DOMAIN=impulse-nutrition-vitavea.myshopify.com
SHOPIFY_CLIENT_ID=replace_me
SHOPIFY_CLIENT_SECRET=replace_me
# Pinned API version, bump when Shopify deprecates.
SHOPIFY_API_VERSION=2024-10

# -- BigBlue (bigblue_mcp) --------------------------------------------------
BIGBLUE_EMAIL=achabrat@havea.com
BIGBLUE_API_KEY=replace_me
# Session token rotates every ~24h. Refresh via the `trigger_token_refresh`
# tool, or run the browser flow and paste the new token here.
BIGBLUE_SESSION_TOKEN=replace_me

# -- TikTok Shop (Tiktok/MCP-TikTokShop) ------------------------------------
# Access token rotates every ~15 days. Refresh via the MCP's `npm run auth`.
TIKTOK_SHOP_APP_KEY=replace_me
TIKTOK_SHOP_APP_SECRET=replace_me
TIKTOK_SHOP_ACCESS_TOKEN=replace_me
TIKTOK_SHOP_SHOP_CIPHER=replace_me
